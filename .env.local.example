# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# URL pública do site (usado em sitemap, Open Graph, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://reservaturismo.com.br

# Stripe (pagamentos)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Token Secreto para Revalidação de Cache (On-Demand ISR)
# Use um valor longo e aleatório. Deve ser o mesmo no Vercel.
# Ex: openssl rand -base64 32
REVALIDATION_SECRET_TOKEN=make-this-a-long-random-string-for-security

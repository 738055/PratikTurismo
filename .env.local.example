# =====================================================================
# Reserva Turismo ERP — variáveis de ambiente
# Copie para `.env.local` (dev) e configure no Vercel (produção).
# =====================================================================

# ---------------------------------------------------------------------
# Supabase (OBRIGATÓRIO)
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Service Role Key — usada em rotas de servidor (admin) para operações
# privilegiadas. NUNCA exponha no client. (OBRIGATÓRIO)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ---------------------------------------------------------------------
# URLs públicas
# ---------------------------------------------------------------------
# Usado em sitemap, Open Graph, JSON-LD (SEO).
NEXT_PUBLIC_SITE_URL=https://reservaturismo.com.br

# URL base da própria aplicação — usada para chamadas internas
# (ex.: webhook -> /api/send-voucher). Em produção, o domínio do deploy.
NEXT_PUBLIC_APP_URL=https://reservaturismo.com.br
# Opcional: sobrescreve NEXT_PUBLIC_APP_URL para chamadas de API internas.
# NEXT_PUBLIC_API_BASE_URL=https://reservaturismo.com.br

# ---------------------------------------------------------------------
# Stripe (pagamentos)
# As chaves Stripe (secret/publishable/webhook) são configuradas no ERP
# em System Settings (tabela system_settings), via painel admin.
# STRIPE_SECRET_KEY abaixo é apenas FALLBACK opcional caso o registro
# em system_settings não esteja preenchido.
# ---------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...

# ---------------------------------------------------------------------
# Revalidação de cache On-Demand (ISR)
# Use um valor longo e aleatório. Deve ser o mesmo configurado no Vercel.
# Ex: openssl rand -base64 32
# ---------------------------------------------------------------------
REVALIDATION_SECRET_TOKEN=make-this-a-long-random-string-for-security

# ---------------------------------------------------------------------
# Cron Jobs (Vercel Cron)
# Protege os endpoints /api/cron e /api/cron/remarketing.
# O Vercel envia automaticamente "Authorization: Bearer $CRON_SECRET".
# Ex: openssl rand -base64 32
# ---------------------------------------------------------------------
CRON_SECRET=make-this-a-long-random-string-for-cron
